# ─────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────

# Supabase — from https://supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Gemini — from https://aistudio.google.com → Get API Key
# One key covers: Gemini 2.5 Flash + Gemini 1.5 Flash + text-embedding-004
GEMINI_API_KEY=your-gemini-api-key-here

# Groq — from https://console.groq.com → API Keys
GROQ_API_KEY=your-groq-api-key-here

# football-data.org — from https://www.football-data.org/client/register
FOOTBALL_DATA_API_KEY=your-football-api-key-here

# Cron secret — random string you create, used to secure Edge Function triggers
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=your-random-cron-secret-here

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
